# Copy this file to .env.local (gitignored). Never commit real keys or paste them in chat.
# For Vercel, configure the same values under Project Settings -> Environment Variables.
#
# Target: Sepolia
NEXT_PUBLIC_RPC_URL=https://sepolia.infura.io/v3/<YOUR_PROJECT_ID>
NEXT_PUBLIC_FACTORY_ADDRESS=0xYourSepoliaFactoryAddress
NEXT_PUBLIC_EXPLORER_URL=https://sepolia.etherscan.io
#
# Optional assistant + monitoring:
# GROQ_API_KEY=gsk_...
# NEXT_PUBLIC_SENTRY_DSN=https://...
# SENTRY_DSN=https://...
